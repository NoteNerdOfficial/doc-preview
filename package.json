{
  "name": "doc-preview",
  "version": "1.0.10",
  "description": "Preview PowerPoint and Word documents. Automatically refreshes when you, Claude, or another AI agent changes the file, so your preview is always up to date. Renders via a local LibreOffice install.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src/"
  },
  "keywords": [],
  "author": "notenerd",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.17.19",
    "eslint": "^9.30.1",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.35.1"
  },
  "dependencies": {
    "@types/node": "^16.11.6",
    "https-proxy-agent": "^7.0.6",
    "pdfjs-dist": "^4.8.69"
  }
}
